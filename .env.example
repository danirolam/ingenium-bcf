# --- Google Gemini ---
# Required for real bill -> delta extraction and client impact analysis.
# If empty, the server falls back to canned demo data (still usable for the demo).
# Get a free key from: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Optional: override the model.
# - gemini-2.5-flash  (default, fast + cheap, good for hackathon demos)
# - gemini-3-flash    (use this if your key is on the new free tier / Cloud Trial Billing)
# - gemini-2.5-pro    (higher quality, paid tier only)
GEMINI_MODEL=gemini-2.5-flash

# --- Resend (transactional email) ---
# Optional. If empty, lawyer notification emails are simulated (logged, not sent).
# Get a key at: https://resend.com
RESEND_API_KEY=
RESEND_FROM=Ingenium <onboarding@resend.dev>
NOTIFY_EMAIL=lawyer@example.com

# --- Server ---
PORT=8787
